# Copy this file to `.env` and fill in the values. Vite exposes only VITE_* vars.

# Clerk publishable key (public). Blank = built-in email-login fallback.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# n8n triage webhook (the live agent).
VITE_TRIAGE_URL=https://n8n.navada-edge-server.uk/webhook/claims-triage

# URL opened by the "live n8n workflow" links.
VITE_N8N_WORKFLOW_URL=http://localhost:5678/workflow/JeenClaimsChat1
