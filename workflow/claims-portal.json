{"id": "JeenClaimsPortal1", "name": "Albion Mutual — Claims Portal (hosted UI)", "active": false, "nodes": [{"parameters": {"httpMethod": "GET", "path": "claims-portal", "responseMode": "responseNode", "options": {}}, "id": "p1000000-0000-0000-0000-000000000001", "name": "GET /claims-portal", "type": "n8n-nodes-base.webhook", "typeVersion": 2, "position": [0, 300], "webhookId": "claims-portal-albion"}, {"parameters": {"respondWith": "text", "responseBody": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Albion Mutual · AI Claims Triage — powered by Jeen</title>\n<meta name=\"description\" content=\"A governed AI claims-triage agent. Submit a claim and watch it get classified, risk-scored and routed — with a human in the loop on anything sensitive.\">\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap\" rel=\"stylesheet\">\n<style>\n  :root{\n    --ink:#16141c; --ink2:#46424f; --muted:#8a8693; --line:#eceaf1; --soft:#f7f6fa; --paper:#fff;\n    --rose:#ec4e83; --coral:#fb6a3b; --violet:#7c5cfc; --teal:#16b6a3;\n    --green:#12a594; --amber:#e8870b; --red:#e23d6e;\n    --shadow:0 18px 50px rgba(28,20,45,.10); --shadow2:0 8px 24px rgba(28,20,45,.08);\n  }\n  *{box-sizing:border-box;margin:0;padding:0}\n  html{scroll-behavior:smooth}\n  body{font-family:\"Inter\",-apple-system,BlinkMacSystemFont,\"Segoe UI\",Arial,sans-serif;color:var(--ink);background:#fbfaff;-webkit-font-smoothing:antialiased;line-height:1.5}\n  .wrap{max-width:1080px;margin:0 auto;padding:0 24px}\n  a{color:inherit;text-decoration:none}\n  /* Jeen mark */\n  .mark{display:inline-grid;grid-template-columns:repeat(2,10px);grid-gap:3px;vertical-align:middle}\n  .mark i{width:10px;height:10px;border-radius:3px;display:block}\n  .mark i:nth-child(1){background:var(--rose)} .mark i:nth-child(2){background:var(--coral)}\n  .mark i:nth-child(3){background:var(--violet)} .mark i:nth-child(4){background:var(--teal)}\n  /* nav */\n  nav{position:sticky;top:0;z-index:50;background:rgba(251,250,255,.82);backdrop-filter:saturate(160%) blur(12px);border-bottom:1px solid var(--line)}\n  nav .wrap{display:flex;align-items:center;justify-content:space-between;height:62px}\n  .brand{display:flex;align-items:center;gap:11px;font-weight:800;letter-spacing:-.02em;font-size:16px}\n  .brand .div{width:1px;height:18px;background:var(--line)}\n  .brand .sub{font-weight:600;color:var(--ink2);font-size:14px}\n  .powered{font-size:12px;color:var(--muted);display:flex;align-items:center;gap:7px}\n  .btn{display:inline-flex;align-items:center;gap:9px;background:var(--ink);color:#fff;font-weight:600;font-size:14px;\n    padding:11px 20px;border-radius:30px;border:0;cursor:pointer;transition:transform .12s ease,box-shadow .2s}\n  .btn:hover{transform:translateY(-1px);box-shadow:var(--shadow2)}\n  .btn.ghost{background:#fff;color:var(--ink);border:1px solid var(--line)}\n  .btn.grad{background:linear-gradient(95deg,var(--violet),var(--rose))}\n  /* hero */\n  .hero{padding:74px 0 30px;position:relative;overflow:hidden}\n  .hero .accent{height:5px;width:128px;border-radius:5px;background:linear-gradient(90deg,var(--rose),var(--coral),var(--violet),var(--teal));margin-bottom:26px}\n  .eyebrow{font-size:12px;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:var(--violet);margin-bottom:18px}\n  h1{font-size:clamp(34px,5vw,54px);line-height:1.04;letter-spacing:-.03em;font-weight:800;max-width:16ch}\n  .lead{font-size:19px;color:var(--ink2);max-width:56ch;margin-top:18px}\n  .herocta{display:flex;gap:12px;margin-top:30px;flex-wrap:wrap}\n  .stats{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-top:54px}\n  .stat{background:var(--paper);border:1px solid var(--line);border-radius:16px;padding:18px 20px;box-shadow:var(--shadow2)}\n  .stat .n{font-size:26px;font-weight:800;letter-spacing:-.02em;background:linear-gradient(90deg,var(--rose),var(--violet));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent}\n  .stat .l{font-size:12.5px;color:var(--ink2);margin-top:5px;line-height:1.35}\n  /* sections */\n  section{padding:46px 0}\n  .sectlabel{font-size:12px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--violet);margin-bottom:12px}\n  h2{font-size:clamp(26px,3.4vw,36px);letter-spacing:-.025em;font-weight:800;line-height:1.1;max-width:20ch}\n  .grid2{display:grid;grid-template-columns:1fr 1fr;gap:22px;margin-top:26px}\n  .card{background:var(--paper);border:1px solid var(--line);border-radius:18px;padding:24px;box-shadow:var(--shadow2)}\n  .card h3{font-size:16px;font-weight:700;margin-bottom:12px;display:flex;align-items:center;gap:9px}\n  .card ul{list-style:none;display:flex;flex-direction:column;gap:10px}\n  .card li{font-size:14.5px;color:var(--ink2);padding-left:22px;position:relative;line-height:1.4}\n  .card li::before{content:\"\";position:absolute;left:0;top:7px;width:8px;height:8px;border-radius:2px;background:var(--violet)}\n  .card.warn li::before{background:var(--coral)} .card.good li::before{background:var(--teal)}\n  .card li b{color:var(--ink);font-weight:700}\n  /* playground */\n  .play{background:linear-gradient(180deg,#1a1326,#120e1c);color:#fff;border-radius:28px;padding:38px;margin-top:8px;box-shadow:0 30px 80px rgba(20,12,40,.4)}\n  .play .eyebrow{color:#d8bef9}\n  .play h2{color:#fff}\n  .play .pl-lead{color:#c6bdd6;font-size:16px;margin-top:10px;max-width:60ch}\n  .scenarios{display:flex;flex-wrap:wrap;gap:9px;margin:22px 0 6px}\n  .chip{font-size:12.5px;font-weight:600;color:#e9e3f5;background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.14);\n    padding:8px 13px;border-radius:22px;cursor:pointer;transition:.15s;display:flex;align-items:center;gap:7px}\n  .chip:hover{background:rgba(255,255,255,.14);transform:translateY(-1px)}\n  .chip .dot{width:8px;height:8px;border-radius:50%}\n  .playgrid{display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-top:20px}\n  @media(max-width:820px){.playgrid{grid-template-columns:1fr}.grid2{grid-template-columns:1fr}.stats{grid-template-columns:1fr 1fr}.flow{flex-direction:column}}\n  .field{margin-bottom:13px}\n  .field label{display:block;font-size:12px;font-weight:600;color:#b7aecb;margin-bottom:6px;letter-spacing:.01em}\n  .field input,.field select,.field textarea{width:100%;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.16);\n    border-radius:11px;padding:11px 13px;color:#fff;font-family:inherit;font-size:14px;outline:none;transition:.15s}\n  .field input:focus,.field select:focus,.field textarea:focus{border-color:var(--violet);background:rgba(255,255,255,.1)}\n  .field textarea{resize:vertical;min-height:84px}\n  .field select option{color:#111}\n  .two{display:grid;grid-template-columns:1fr 1fr;gap:12px}\n  .runbtn{width:100%;background:linear-gradient(95deg,var(--violet),var(--rose));color:#fff;border:0;border-radius:12px;\n    padding:14px;font-weight:700;font-size:15px;cursor:pointer;margin-top:6px;transition:.15s;display:flex;align-items:center;justify-content:center;gap:10px}\n  .runbtn:hover{filter:brightness(1.07)} .runbtn:disabled{opacity:.6;cursor:not-allowed}\n  /* result panel */\n  .result{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.12);border-radius:16px;padding:22px;min-height:420px;display:flex;flex-direction:column}\n  .res-empty{margin:auto;text-align:center;color:#8e85a3;max-width:30ch}\n  .res-empty .big{font-size:34px;margin-bottom:12px}\n  .spinner{width:34px;height:34px;border:3px solid rgba(255,255,255,.2);border-top-color:var(--violet);border-radius:50%;animation:spin .8s linear infinite;margin:0 auto 14px}\n  @keyframes spin{to{transform:rotate(360deg)}}\n  .res-head{display:flex;justify-content:space-between;align-items:flex-start;gap:12px;padding-bottom:14px;border-bottom:1px solid rgba(255,255,255,.1)}\n  .ref{font-family:ui-monospace,Menlo,monospace;font-size:13px;color:#cbbff0;background:rgba(124,92,252,.18);padding:5px 10px;border-radius:8px}\n  .routebadge{font-size:12.5px;font-weight:800;letter-spacing:.03em;text-transform:uppercase;padding:7px 13px;border-radius:24px}\n  .route-auto{background:rgba(18,165,148,.2);color:#5fe6cf;border:1px solid rgba(18,165,148,.4)}\n  .route-adjuster{background:rgba(232,135,11,.2);color:#ffc266;border:1px solid rgba(232,135,11,.4)}\n  .route-fraud{background:rgba(226,61,110,.2);color:#ff86a8;border:1px solid rgba(226,61,110,.4)}\n  .res-chips{display:flex;flex-wrap:wrap;gap:8px;margin:16px 0}\n  .rchip{font-size:12px;font-weight:600;padding:6px 11px;border-radius:20px;background:rgba(255,255,255,.08);color:#ddd5ec;border:1px solid rgba(255,255,255,.12)}\n  .rchip.vuln{background:rgba(236,78,131,.18);color:#ffa6c2;border-color:rgba(236,78,131,.4)}\n  .meter-wrap{margin:14px 0}\n  .meter-top{display:flex;justify-content:space-between;font-size:12.5px;color:#b7aecb;margin-bottom:6px}\n  .meter{height:9px;background:rgba(255,255,255,.1);border-radius:6px;overflow:hidden}\n  .meter .fill{height:100%;border-radius:6px;width:0;transition:width .9s cubic-bezier(.2,.8,.2,1)}\n  .summary{font-size:14px;color:#e4ddf0;line-height:1.5;background:rgba(255,255,255,.05);border-radius:11px;padding:13px;margin-top:8px}\n  .summary .lbl{font-size:11px;text-transform:uppercase;letter-spacing:.08em;color:#9a90b3;font-weight:700;margin-bottom:5px}\n  .nextstep{font-size:13.5px;color:#cde9e3;background:rgba(18,182,163,.12);border:1px solid rgba(18,182,163,.3);border-radius:11px;padding:12px;margin-top:12px;display:flex;gap:9px}\n  .steps{display:flex;gap:6px;margin-top:14px;font-size:11px;color:#9a90b3;flex-wrap:wrap}\n  .steps span{background:rgba(255,255,255,.06);padding:5px 9px;border-radius:7px}\n  .steps .on{color:#fff;background:rgba(124,92,252,.3)}\n  .banner{background:rgba(232,135,11,.14);border:1px solid rgba(232,135,11,.35);color:#ffce8e;border-radius:11px;padding:11px 13px;font-size:13px;margin-top:14px}\n  /* flow */\n  .flow{display:flex;align-items:stretch;gap:0;margin-top:26px;flex-wrap:wrap}\n  .step{background:var(--paper);border:1px solid var(--line);border-radius:14px;padding:16px;flex:1;min-width:150px;box-shadow:var(--shadow2)}\n  .step .t{font-size:11.5px;font-weight:800;letter-spacing:.04em;text-transform:uppercase;color:var(--violet);margin-bottom:6px}\n  .step .d{font-size:13px;color:var(--ink2);line-height:1.35}\n  .step .tg{display:inline-block;font-size:10px;font-weight:700;padding:3px 8px;border-radius:14px;margin-top:9px}\n  .tg.llm{background:#efe7ff;color:var(--violet)} .tg.act{background:#d9f6f0;color:#0c8273} .tg.hil{background:#ffe7d6;color:#c2541d}\n  .arrow{display:flex;align-items:center;justify-content:center;color:#cdc6da;font-size:20px;padding:0 8px}\n  .govnote{margin-top:22px;background:var(--soft);border:1px solid var(--line);border-radius:16px;padding:20px;font-size:14.5px;color:var(--ink2);line-height:1.55}\n  .govnote b{color:var(--ink)}\n  footer{padding:40px 0;border-top:1px solid var(--line);margin-top:30px;color:var(--muted);font-size:13px}\n  footer .wrap{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px}\n  .demo-note{font-size:12px;color:var(--muted);text-align:center;margin-top:16px}\n</style>\n</head>\n<body>\n\n<nav>\n  <div class=\"wrap\">\n    <div class=\"brand\">\n      <span class=\"mark\"><i></i><i></i><i></i><i></i></span>\n      Albion Mutual <span class=\"div\"></span><span class=\"sub\">Claims</span>\n    </div>\n    <div style=\"display:flex;align-items:center;gap:18px\">\n      <span class=\"powered\"><span class=\"mark\" style=\"grid-template-columns:repeat(2,7px);grid-gap:2px\"><i style=\"width:7px;height:7px\"></i><i style=\"width:7px;height:7px\"></i><i style=\"width:7px;height:7px\"></i><i style=\"width:7px;height:7px\"></i></span> powered by Jeen</span>\n      <a href=\"#try\" class=\"btn\">Try the agent</a>\n    </div>\n  </div>\n</nav>\n\n<header class=\"hero\">\n  <div class=\"wrap\">\n    <div class=\"accent\"></div>\n    <div class=\"eyebrow\">AI Solution Engineer demo · governed agent workflow</div>\n    <h1>From claim to decision in seconds — with a human in the loop.</h1>\n    <p class=\"lead\">A governed AI agent that reads each new insurance claim, classifies it, scores fraud risk, flags vulnerable customers under FCA Consumer Duty, and routes it — automatically settling the clean ones and escalating anything sensitive to a person.</p>\n    <div class=\"herocta\">\n      <a href=\"#try\" class=\"btn grad\">▶ Try it live</a>\n      <a href=\"#how\" class=\"btn ghost\">See how it works</a>\n    </div>\n    <div class=\"stats\">\n      <div class=\"stat\"><div class=\"n\">~60%</div><div class=\"l\">of triage effort is low-value, repetitive reading</div></div>\n      <div class=\"stat\"><div class=\"n\">&lt;5s</div><div class=\"l\">from submission to a structured, routed decision</div></div>\n      <div class=\"stat\"><div class=\"n\">FCA</div><div class=\"l\">Consumer-Duty vulnerability flag on every claim</div></div>\n      <div class=\"stat\"><div class=\"n\">100%</div><div class=\"l\">of sensitive claims held for human approval</div></div>\n    </div>\n  </div>\n</header>\n\n<section>\n  <div class=\"wrap\">\n    <div class=\"sectlabel\">The problem</div>\n    <h2>Every claim is triaged by hand. That's slow, inconsistent, and risky.</h2>\n    <div class=\"grid2\">\n      <div class=\"card warn\">\n        <h3>🔻 Current pain points</h3>\n        <ul>\n          <li>Manual classification &amp; routing of <b>every</b> First Notice of Loss</li>\n          <li>No consistent, auditable <b>fraud-risk scoring</b> at intake</li>\n          <li><b>Vulnerable customers</b> identified late, if at all</li>\n          <li>Slow first response erodes trust and breaches SLAs</li>\n        </ul>\n      </div>\n      <div class=\"card good\">\n        <h3>✦ What the agent delivers</h3>\n        <ul>\n          <li><b>Straight-through</b> processing of clean, low-value claims</li>\n          <li>Adjusters spend time only on claims that need <b>judgement</b></li>\n          <li>Consistent fraud &amp; vulnerability flags from day one — fully <b>audited</b></li>\n          <li>A defensible record of <b>every decision</b>, human or automated</li>\n        </ul>\n      </div>\n    </div>\n  </div>\n</section>\n\n<section id=\"try\">\n  <div class=\"wrap\">\n    <div class=\"play\">\n      <div class=\"eyebrow\">Live playground</div>\n      <h2>Submit a claim. Watch the agent decide.</h2>\n      <p class=\"pl-lead\">Click a sample scenario to auto-fill, or write your own. The agent runs a real LLM triage step, records the claim, and returns its routing decision.</p>\n      <div class=\"scenarios\" id=\"scenarios\"></div>\n      <div class=\"playgrid\">\n        <form id=\"claimForm\" autocomplete=\"off\">\n          <div class=\"two\">\n            <div class=\"field\"><label>Policy number</label><input name=\"policy_number\" required></div>\n            <div class=\"field\"><label>Incident type</label>\n              <select name=\"incident_type\"><option>Motor</option><option>Home</option><option>Travel</option><option>Liability</option></select></div>\n          </div>\n          <div class=\"two\">\n            <div class=\"field\"><label>Claimant name</label><input name=\"claimant_name\" required></div>\n            <div class=\"field\"><label>Claimant email</label><input name=\"claimant_email\" type=\"email\" required></div>\n          </div>\n          <div class=\"two\">\n            <div class=\"field\"><label>Incident date</label><input name=\"incident_date\" type=\"date\" required></div>\n            <div class=\"field\"><label>Estimated value (£)</label><input name=\"estimated_value\" type=\"number\" required></div>\n          </div>\n          <div class=\"field\"><label>Description of incident</label><textarea name=\"description\" required></textarea></div>\n          <button class=\"runbtn\" id=\"runBtn\" type=\"submit\">⚡ Run AI triage</button>\n        </form>\n        <div class=\"result\" id=\"result\">\n          <div class=\"res-empty\"><div class=\"big\">🧠</div><div>Your triage decision will appear here.<br>Pick a scenario to get started.</div></div>\n        </div>\n      </div>\n      <div class=\"demo-note\" id=\"demoNote\"></div>\n    </div>\n  </div>\n</section>\n\n<section id=\"how\">\n  <div class=\"wrap\">\n    <div class=\"sectlabel\">How it works</div>\n    <h2>One workflow orchestrating data, a model, and human oversight.</h2>\n    <div class=\"flow\">\n      <div class=\"step\"><div class=\"t\">1 · Intake</div><div class=\"d\">Claimant submits the claim through this portal.</div></div>\n      <div class=\"arrow\">→</div>\n      <div class=\"step\"><div class=\"t\">2 · AI triage</div><div class=\"d\">An LLM classifies, scores fraud, flags vulnerability and recommends routing.</div><span class=\"tg llm\">LLM decision</span></div>\n      <div class=\"arrow\">→</div>\n      <div class=\"step\"><div class=\"t\">3 · Record</div><div class=\"d\">The claim and assessment are written to a Postgres system of record.</div><span class=\"tg act\">Action</span></div>\n      <div class=\"arrow\">→</div>\n      <div class=\"step\"><div class=\"t\">4 · Route</div><div class=\"d\">Clean claims auto-settle; sensitive ones pause for an adjuster.</div><span class=\"tg hil\">Human approval</span></div>\n    </div>\n    <div class=\"govnote\">\n      <b>Governed by design.</b> The LLM is scoped to a decision — it never settles or rejects a claim on its own. High-value (≥£10k), high-fraud-risk (≥60) or vulnerable-customer claims are always held for a human adjuster to approve or reject. Every claim and every decision is logged, giving a defensible audit trail. <b>Stack:</b> n8n (orchestration) · OpenAI GPT-4o-mini (triage) · PostgreSQL (record) · Cloudflare (hosting).\n    </div>\n  </div>\n</section>\n\n<footer>\n  <div class=\"wrap\">\n    <div class=\"brand\"><span class=\"mark\"><i></i><i></i><i></i><i></i></span> Albion Mutual <span class=\"div\"></span><span class=\"sub\">Claims Triage Agent</span></div>\n    <div>Demo build · Leslie Akpareva · powered by Jeen — AI on your terms</div>\n  </div>\n</footer>\n\n<script>\nconst SCENARIOS = [\n  {label:\"Low-risk motor scrape\", color:\"#16b6a3\", data:{policy_number:\"ALB-MOT-441902\",claimant_name:\"Daniel Hughes\",claimant_email:\"demo@example.com\",incident_type:\"Motor\",incident_date:\"2026-05-21\",estimated_value:480,description:\"Minor car park scrape on the rear bumper of my Ford Focus while parked at the supermarket. Small scratch and a cracked indicator cover. No other vehicle involved, no injuries. Policy held for 4 years.\"}},\n  {label:\"£46k kitchen fire\", color:\"#e8870b\", data:{policy_number:\"ALB-HOM-778145\",claimant_name:\"Priya Nair\",claimant_email:\"demo@example.com\",incident_type:\"Home\",incident_date:\"2026-05-18\",estimated_value:46000,description:\"A kitchen fire caused by a faulty dishwasher spread to the adjoining rooms. Significant smoke and water damage to the ground floor, kitchen units destroyed, and we have had to move into temporary accommodation. Fire brigade attended and have a report.\"}},\n  {label:\"Suspected fraud\", color:\"#e23d6e\", data:{policy_number:\"ALB-MOT-902551\",claimant_name:\"Marcus Webb\",claimant_email:\"demo@example.com\",incident_type:\"Motor\",incident_date:\"2026-05-26\",estimated_value:9000,description:\"Car was stolen from outside a friend's house, total loss. I need this settled as quickly as possible, ideally this week. The car was worth exactly 9000. Policy was taken out recently. I do not have the second key or the purchase receipt anymore.\"}},\n  {label:\"Vulnerable customer\", color:\"#ec4e83\", data:{policy_number:\"ALB-HOM-330218\",claimant_name:\"Eileen Roberts\",claimant_email:\"demo@example.com\",incident_type:\"Home\",incident_date:\"2026-05-20\",estimated_value:3200,description:\"My husband passed away last month and while clearing the house I discovered a burst pipe had damaged the bedroom carpet and ceiling. I am 78, recently bereaved and finding all of this very difficult to deal with on my own. I am not sure what I am supposed to do next.\"}},\n  {label:\"Lost baggage\", color:\"#7c5cfc\", data:{policy_number:\"ALB-TRA-561023\",claimant_name:\"Tom Bedford\",claimant_email:\"demo@example.com\",incident_type:\"Travel\",incident_date:\"2026-05-12\",estimated_value:1450,description:\"Checked baggage was lost by the airline on a flight back from Spain and never recovered. Claiming for clothing, a laptop and toiletries. I have the property irregularity report from the airline and receipts for the main items.\"}},\n];\nconst $ = s => document.querySelector(s);\nconst form = $(\"#claimForm\");\n\n// build scenario chips\nconst sc = $(\"#scenarios\");\nSCENARIOS.forEach((s,i)=>{\n  const c = document.createElement(\"div\"); c.className=\"chip\";\n  c.innerHTML = `<span class=\"dot\" style=\"background:${s.color}\"></span>${s.label}`;\n  c.onclick = ()=>{ for(const k in s.data) form.elements[k].value = s.data[k]; $(\"#try\").scrollIntoView({behavior:\"smooth\"}); };\n  sc.appendChild(c);\n});\n\nfunction routeClass(r){ return r===\"auto-settle\"?\"route-auto\":(r===\"SIU-fraud\"?\"route-fraud\":\"route-adjuster\"); }\nfunction meterColor(v){ return v>=60?\"#e23d6e\":(v>=30?\"#e8870b\":\"#12a594\"); }\n\nform.addEventListener(\"submit\", async (e)=>{\n  e.preventDefault();\n  const btn = $(\"#runBtn\"); btn.disabled=true; btn.textContent=\"Running triage…\";\n  const res = $(\"#result\");\n  res.innerHTML = `<div class=\"res-empty\"><div class=\"spinner\"></div><div>The agent is reading the claim, scoring risk and deciding how to route it…</div></div>`;\n  const payload = Object.fromEntries(new FormData(form).entries());\n  payload.estimated_value = Number(payload.estimated_value);\n  try{\n    const r = await fetch(\"/webhook/claims-triage\", {method:\"POST\", headers:{\"Content-Type\":\"application/json\"}, body:JSON.stringify(payload)});\n    const d = await r.json();\n    if(!r.ok || d.ok===false || !d.routing) throw new Error(d.detail || d.error || \"Agent did not return a decision\");\n    renderResult(d);\n  }catch(err){\n    res.innerHTML = `<div class=\"res-empty\"><div class=\"big\">⚠️</div><div>The agent isn't reachable yet.<br><span style=\"font-size:12px;color:#8e85a3\">${(err.message||err)}</span></div></div>`;\n  }finally{ btn.disabled=false; btn.textContent=\"⚡ Run AI triage\"; }\n});\n\nfunction renderResult(d){\n  const rc = routeClass(d.routing);\n  const mc = meterColor(d.fraud_risk);\n  const html = `\n    <div class=\"res-head\">\n      <div><div class=\"ref\">${d.claim_ref||\"—\"}</div>\n      <div style=\"font-size:12px;color:#9a90b3;margin-top:8px\">Status: ${d.status||\"\"}</div></div>\n      <div class=\"routebadge ${rc}\">${(d.routing||\"\").replace(\"-\",\" \")}</div>\n    </div>\n    <div class=\"res-chips\">\n      <span class=\"rchip\">${d.claim_type||\"\"}</span>\n      <span class=\"rchip\">Severity: ${d.severity||\"\"}</span>\n      <span class=\"rchip\">£${Number(d.estimated_value||0).toLocaleString()}</span>\n      ${d.vulnerable_flag?'<span class=\"rchip vuln\">⚑ Vulnerable customer</span>':''}\n    </div>\n    <div class=\"meter-wrap\">\n      <div class=\"meter-top\"><span>Fraud risk</span><span style=\"color:${mc};font-weight:700\">${d.fraud_risk}/100</span></div>\n      <div class=\"meter\"><div class=\"fill\" style=\"background:${mc}\"></div></div>\n      <div style=\"font-size:12px;color:#9a90b3;margin-top:7px\">${d.fraud_reasons||\"\"}</div>\n    </div>\n    ${d.vulnerable_flag?`<div class=\"banner\">⚑ <b>FCA Consumer Duty:</b> ${d.vulnerable_reason||\"Potential vulnerability detected — routed to a person.\"}</div>`:''}\n    <div class=\"summary\"><div class=\"lbl\">AI triage summary</div>${d.ai_summary||\"\"}</div>\n    <div class=\"nextstep\">➜ <div><b>What happens next:</b> ${d.next_step||\"\"}</div></div>\n    <div class=\"steps\">\n      <span class=\"on\">Intake ✓</span><span class=\"on\">AI triage ✓</span><span class=\"on\">Recorded ✓</span>\n      <span class=\"${d.routing==='auto-settle'?'on':''}\">${d.routing==='auto-settle'?'Auto-settled ✓':'Awaiting adjuster'}</span>\n    </div>`;\n  const res = $(\"#result\"); res.innerHTML = html;\n  requestAnimationFrame(()=>{ res.querySelector(\".fill\").style.width = Math.max(4,Math.min(100,d.fraud_risk))+\"%\"; });\n}\n</script>\n</body>\n</html>\n", "options": {"responseHeaders": {"entries": [{"name": "Content-Type", "value": "text/html; charset=utf-8"}]}}}, "id": "p1000000-0000-0000-0000-000000000002", "name": "Serve Portal HTML", "type": "n8n-nodes-base.respondToWebhook", "typeVersion": 1.1, "position": [260, 300]}], "connections": {"GET /claims-portal": {"main": [[{"node": "Serve Portal HTML", "type": "main", "index": 0}]]}}, "settings": {"executionOrder": "v1"}, "pinData": {}}